SUNSHINE_NAS_ROOT=/mnt/sunshine
POSTGRES_USER=sunshine
POSTGRES_PASSWORD=local
POSTGRES_DB=sunshine_club
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sunshine:local@localhost:5432/sunshine_club
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
API_PORT=8000
DASHBOARD_PORT=3000
SUNSHINE_RUN_EXECUTION_BACKEND=subprocess
SUNSHINE_VECTOR_STORE=qdrant
SUNSHINE_QDRANT_URL=http://localhost:6333
SUNSHINE_QDRANT_COLLECTION=sunshine_chunks
SUNSHINE_RUNTIME_MODE=development
SUNSHINE_REQUIRE_LOCAL_MODEL_CACHE=0

# LLM tag classification.
# OPENAI_API is accepted for local developer convenience and normalized to OPENAI_API_KEY at runtime.
# CORTEX_API_KEY is accepted for Cortex chat, embeddings, OCR, and normalized to OpenAI-compatible aliases.
OPENAI_API=
OPENAI_API_KEY=
SUNSHINE_LLM_TAG_PROVIDER=cortex
CORTEX_BASE_URL=https://cortex.vallery.net
CORTEX_API_KEY=
CORTEX_OPENAI_BASE_URL=https://cortex.vallery.net/v1
CORTEX_MODEL=gemma4-26b
CORTEX_OPENAI_API_KEY=

# Embeddings.
SUNSHINE_EMBEDDING_PROVIDER=cortex
SUNSHINE_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
SUNSHINE_EMBEDDING_DIMENSIONS=1024

# OCR fallback. Local OCR runs first; Cortex OCR is used only when local OCR is poor, empty, failed, or suspicious.
SUNSHINE_OCR_FALLBACK_PROVIDER=cortex
CORTEX_OCR_MODEL=paddleocr-ppocr-cpu
